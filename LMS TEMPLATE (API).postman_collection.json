      "item": [
        {
          "name": "Create Checklist Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Default Performance Checklist\",\n  \"description\": \"Annual performance KPIs\",\n  \"items\": [\n    {\n      \"name\": \"Attendance\",\n      \"description\": \"Overall attendance percentage\",\n      \"itemType\": \"quantitative\",\n      \"targetValue\": 95,\n      \"threshold\": 90,\n      \"unit\": \"%\",\n      \"weight\": 2,\n      \"dataSource\": \"lms\"\n    },\n    {\n      \"name\": \"Certificates\",\n      \"description\": \"Certificates required per year\",\n      \"itemType\": \"certification\",\n      \"targetValue\": 5,\n      \"threshold\": 5,\n      \"unit\": \"count\",\n      \"weight\": 1,\n      \"dataSource\": \"lms\"\n    },\n    {\n      \"name\": \"No Late\",\n      \"description\": \"Number of late arrivals\",\n      \"itemType\": \"quantitative\",\n      \"targetValue\": 0,\n      \"threshold\": 0,\n      \"unit\": \"count\",\n      \"weight\": 1,\n      \"dataSource\": \"manual\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/checklist-template/create",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "checklist-template", "create"]
